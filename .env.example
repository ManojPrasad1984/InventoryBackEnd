# ─────────────────────────────────────────────────────────────
# Backend — local.settings.json equivalent as .env
# Copy to local.settings.json for Azure Functions local dev
# NEVER commit actual values — only this .env.example
# ─────────────────────────────────────────────────────────────

# Azure SQL Database
DB_SERVER=your-server.database.windows.net
DB_NAME=pepsidealer_db
DB_USER=pepsidealer_app
DB_PASSWORD=YourStrongPassword123!

# JWT
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRY=8h
JWT_REFRESH_EXPIRY=30d

# Twilio (SMS + WhatsApp + Voice)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# SendGrid (Email)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Azure Storage (for report exports)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;...

# App
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.azurestaticapps.net
